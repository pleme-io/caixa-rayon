        devDependencies = [
          {
            name = "syn";
            packageId = "syn";
            features = [ "visit" ];
          }
        ];

      };
      "zmij" = rec {
        crateName = "zmij";
        version = "1.0.21";
        edition = "2021";
        sha256 = "1amb5i6gz7yjb0dnmz5y669674pqmwbj44p4yfxfv2ncgvk8x15q";
        authors = [
          "David Tolnay <dtolnay@gmail.com>"
        ];
        features = {
          "no-panic" = [ "dep:no-panic" ];
