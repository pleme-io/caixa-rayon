        ];

      };
      "zerocopy" = rec {
        crateName = "zerocopy";
        version = "0.8.48";
        edition = "2021";
        sha256 = "1sb8plax8jbrsng1jdval7bdhk7hhrx40dz3hwh074k6knzkgm7f";
        authors = [
          "Joshua Liebow-Feeser <joshlf@google.com>"
          "Jack Wrenn <jswrenn@amazon.com>"
