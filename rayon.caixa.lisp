   :body "#![type_length_limit = \"10000\"]\n\nuse rayon::prelude::*;\n\n#[test]\nfn type_length_limit() {\n    let input = vec![1, 2, 3, 4, 5];\n    let (indexes, (squares, cubes)): (Vec<_>, (Vec<_>, Vec<_>)) = input\n        .par_iter()\n        .map(|x| (x * x, x * x * x))\n        .enumerate()\n        .unzip();\n\n    drop(indexes);\n    drop(squares);\n    drop(cubes);\n}\n"} {:path "tests/issue671.rs"
