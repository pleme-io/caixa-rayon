   :body "#![type_length_limit = \"500000\"]\n\nuse rayon::prelude::*;\n\n#[test]\nfn type_length_limit() {\n    let _ = Vec::<Result<(), ()>>::new()\n        .into_par_iter()\n        .map(|x| x)\n        .map(|x| x)\n        .map(|x| x)\n        .map(|x| x)\n        .map(|x| x)\n        .map(|x| x)\n        .collect::<Result<(), ()>>();\n}\n"} {:path "tests/str.rs"
